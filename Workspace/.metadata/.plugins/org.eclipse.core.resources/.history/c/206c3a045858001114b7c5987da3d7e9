package com.inheritance;

interface Client1 {
	public int add(int x, int y);
}
interface Client2 {
	public int sub(int x, int y);
}

class Server implements Client1, Client2 {
	@Override
	public int add(int x, int y) {
		// TODO Auto-generated method stub
		return x+y;
	}
	@Override
	public int sub(int x, int y) {
		// TODO Auto-generated method stub
		return x-y;
	}
}
